# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Database (Supabase Transaction pooler - port 6543, requires prepare: false)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres

# NextAuth
AUTH_SECRET=your-auth-secret

# SAM.gov API
SAM_GOV_API_KEY=your-sam-gov-api-key

# Anthropic (AI 분석)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Resend (email)
RESEND_API_KEY=your-resend-api-key

# Vercel Cron Secret
CRON_SECRET=your-cron-secret
